PAYSTACK_SECRET=sk_test_replace_me
FIREBASE_PROJECT_ID=replace_me
PORT=8080

# Daraja (M-PESA) configuration
# Select environment: sandbox | production
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=replace_me
DARAJA_CONSUMER_SECRET=replace_me
# LNMO Shortcode:
# - Sandbox default: 174379
# - Production: set to your BuyGoods till (e.g., 9272931) if LNMO enabled
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=replace_me
# Transaction Type:
# - For PayBill: CustomerPayBillOnline (default)
# - For BuyGoods Till: CustomerBuyGoodsOnline
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline
# Public base URL for callbacks (e.g., https://api.example.com)
BASE_URL_PUBLIC=https://example.com
# Callback path appended to BASE_URL_PUBLIC to form full callback URL
DARAJA_CALLBACK_PATH=/api/payments/mpesa/callback
MPESA_ENABLED=true
# Optional: allow only these IPs to post to callback (comma-separated)
DARAJA_CALLBACK_ALLOWLIST=196.201.214.200,196.201.214.206
ADMIN_UIDS=

# Firebase Web SDK config for admin UI (email/password login)
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=

# Optional: Cloud Storage bucket for scheduled CSV exports (defaults to <project>.appspot.com)
EXPORT_BUCKET=

# BigQuery export (optional)
BIGQUERY_DATASET=
BIGQUERY_TABLE=

# Functions region (default us-central1). For Kenya, consider africa-south1
FUNCTIONS_REGION=us-central1
